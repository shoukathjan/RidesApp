# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGINS=http://localhost:5173,http://localhost:19006

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# OTP (stubbed for now). In dev, any phone accepts this fixed code.
DEV_OTP=123456

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/useme

# Razorpay (driver subscriptions)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Public URL phones can reach for WebView checkout (use your LAN IP in dev)
PUBLIC_API_URL=http://192.168.1.5:4000

# AWS S3 (driver document uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=xxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxx
S3_BUCKET=useme-driver-docs

# Defaults
DEFAULT_REQUEST_RADIUS_KM=10

# Places search (OSM/Nominatim — no key required)
PLACES_USER_AGENT=UseMe/1.0 (contact@useme.app)

# Optional — Google Places fallback for landmarks/cities (client-borne API cost)
GOOGLE_PLACES_API_KEY=

# Optional — road distance for fare estimates (falls back to straight-line if unset)
OPENROUTESERVICE_API_KEY=
