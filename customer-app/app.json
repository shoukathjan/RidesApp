{
  "expo": {
    "name": "GetMeRide",
    "slug": "getmeride-customer",
    "scheme": "getmeridecustomer",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to set your pickup point."
      }
    },
    "android": {
      "package": "com.getmeride.rider",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "enableFullScreenImage_legacy": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7befc2a9-1417-43c5-941a-222846c7b5c9"
      }
    }
  }
}
